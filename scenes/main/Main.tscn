[sub_resource type="Shader" id="Shader_dialogue_portrait_hologram"]
code = "shader_type canvas_item;

uniform vec4 baseColor : source_color = vec4(0.24, 0.83, 0.97, 1.0);
uniform float speed = 4.0;
uniform vec4 linesColor : source_color = vec4(0.42, 0.95, 1.0, 1.0);
uniform float linesColorIntensity = 1.0;
uniform float lineDensity = 32.0;
uniform float lineWidth = 0.2;
uniform float lineEdgeSoftness = 0.08;
uniform float tintStrength = 0.55;
uniform float lineStrength = 0.1;
uniform float effectStrength = 0.62;
uniform float flickerSpeed = 0.6;
uniform float flickerAmount = 0.02;
uniform float sweepSpeed = 2.0;
uniform float sweepAmount = 0.16;
uniform float sweepWidth = 0.24;

void fragment() {
	vec4 src = texture(TEXTURE, UV);
	float scan = fract((UV.y + TIME * speed * 0.01) * lineDensity);
	float line_dist = abs(scan - 0.5);
	float line_mask = 1.0 - smoothstep(lineWidth, lineWidth + lineEdgeSoftness, line_dist);

	float flicker = 1.0 - flickerAmount + flickerAmount * (0.5 + 0.5 * sin(TIME * flickerSpeed));
	float sweep_center = fract(1.0 - TIME * sweepSpeed * 0.1);
	float sweep = 1.0 + sweepAmount * smoothstep(sweepWidth, 0.0, abs(UV.y - sweep_center));

	vec3 base_tinted = mix(src.rgb, src.rgb * baseColor.rgb, tintStrength);
	vec3 line_tinted = linesColor.rgb * line_mask * lineStrength * linesColorIntensity;
	vec3 hologram = clamp((base_tinted + line_tinted) * flicker * sweep, 0.0, 1.0);

	COLOR.rgb = mix(src.rgb, hologram, effectStrength);
	COLOR.a = src.a;
}"

