[sub_resource type="Shader" id="5"]
code = "shader_type canvas_item;

// Cover depth: elliptical vignette + curved corner darkening to read like a bound journal
uniform float vignette = 0.36;
uniform float grain = 0.045;
uniform float edge_round = 1.8;
uniform float corner_radius = 0.10; // uv-space radius for corner darkening
uniform float corner_dark = 0.28;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
}

void fragment() {
	vec2 c = UV - vec2(0.5, 0.08); // bias slightly toward top for cover pocket
	float r = length(c * vec2(edge_round, 1.0));
	float base = smoothstep(0.30, 0.92, r) * vignette;
	float center_soft = smoothstep(0.0, 0.55, r) * 0.04;
	float n = (hash(UV * vec2(900.0, 700.0)) - 0.5) * grain;
	float alpha = clamp(base - center_soft + n * 0.6, 0.0, 1.0);

	// Corner darkening (each corner adds a soft circular dark spot)
	vec2 uv = UV;
	float d_tl = length(uv - vec2(corner_radius, 1.0 - corner_radius));
	float d_tr = length(uv - vec2(1.0 - corner_radius, 1.0 - corner_radius));
	float d_bl = length(uv - vec2(corner_radius, corner_radius));
	float d_br = length(uv - vec2(1.0 - corner_radius, corner_radius));
	float ct = (1.0 - smoothstep(0.0, corner_radius, d_tl));
	float cr = (1.0 - smoothstep(0.0, corner_radius, d_tr));
	float cb = (1.0 - smoothstep(0.0, corner_radius, d_bl));
	float cl = (1.0 - smoothstep(0.0, corner_radius, d_br));
	float corner_sum = clamp(ct + cr + cb + cl, 0.0, 1.0);
	// soften corner influence toward center so corners don't clip the vignette
	float corner_influence = corner_sum * corner_dark * (1.0 - smoothstep(0.0, 0.9, r));
	alpha = clamp(alpha + corner_influence, 0.0, 1.0);

	COLOR = vec4(0.0, 0.0, 0.0, alpha);
}"

