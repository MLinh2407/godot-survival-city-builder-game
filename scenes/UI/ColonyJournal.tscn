[sub_resource type="Shader" id="14"]
code = "shader_type canvas_item;

// Inner ambient occlusion: softer defaults that fade vertically so shadow disappears naturally
uniform float strength = 0.12;
uniform float falloff = 2.6;
uniform float noise_scale = 420.0;
uniform float side = 1.0; // 1.0 = right gutter, 0.0 = left gutter

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(127.1,311.7))) * 43758.5453123);
}

void fragment(){
	vec2 u = UV;
	float d = side > 0.5 ? (1.0 - u.x) : u.x; // distance from gutter side (0..1)
	// stronger near gutter, softer outward
	float base = pow(clamp(1.0 - smoothstep(0.0, 1.0, d), 0.0, 1.0), falloff) * strength;
	float n = (hash(UV * noise_scale) - 0.5) * 0.02;
	float a = clamp(base + n, 0.0, 1.0);
	// vertical fade so AO gradient disappears toward top/bottom edges
	float vy = smoothstep(0.0, 1.0, 1.0 - abs((u.y - 0.5) * 2.0));
	a *= vy;
	COLOR = vec4(0.0, 0.0, 0.0, a);
}
"

