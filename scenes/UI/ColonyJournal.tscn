[sub_resource type="Shader" id="7"]
code = "shader_type canvas_item;

// Gutter/spine depth: concentrated near center with vertical falloff and noisy edges
uniform float gutter_pos = 1.0;
uniform float gutter_dark = 0.22;
uniform float outer_dark = 0.08;
uniform float edge_dark = 0.06;
uniform float noise_scale = 360.0;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(12.9898,78.233))) * 43758.5453);
}

void fragment() {
	float d_center = abs(UV.x - gutter_pos);
	float dg = exp(-pow(d_center * 14.0, 1.6)) * gutter_dark;
	float do = exp(-pow(abs(UV.x - (1.0 - gutter_pos)) * 10.5, 1.2)) * outer_dark;
	float ey = smoothstep(0.0, 1.0, 1.0 - abs((UV.y - 0.5) * 2.0));
	float de = (ey) * edge_dark * 1.2;
	float n = (hash(UV * noise_scale) - 0.5) * 0.05;
	float a = clamp(dg * 1.05 + do * 0.85 + de + n, 0.0, 1.0);
	// fade the gutter region slightly so it blends into the texture seam
	a *= smoothstep(0.0, 0.95, 1.0 - d_center * 2.0);
	COLOR = vec4(0.0, 0.0, 0.0, a);
}"

