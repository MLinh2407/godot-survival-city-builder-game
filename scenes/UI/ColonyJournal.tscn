[sub_resource type="Shader" id="12"]
code = "shader_type canvas_item;

// Gutter mask using the spine texture luminance to follow actual seam shape
uniform float strength = 0.78;
uniform float noise_scale = 360.0;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(12.9898,78.233))) * 43758.5453);
}

float lum(vec3 c){
	return dot(c, vec3(0.299,0.587,0.114));
}

void fragment(){
	vec4 s = texture(TEXTURE, UV);
	float m = lum(s.rgb);
	// emphasize darker parts of the spine texture as mask
	m = smoothstep(0.18, 0.82, m);
	// vertical softening to avoid hard banding near top/bottom
	float vy = smoothstep(0.12, 0.95, 1.0 - abs((UV.y - 0.5) * 2.0));
	// width fade so it tapers into pages naturally
	float wf = pow(1.0 - abs(UV.x - 0.5) * 2.0, 1.6);
	float n = (hash(UV * noise_scale) - 0.5) * 0.06;
	float a = clamp(m * strength * wf * vy + n, 0.0, 1.0);
	COLOR = vec4(0.0, 0.0, 0.0, a);
}
"

